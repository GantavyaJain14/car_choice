# Root .gitignore for Car Choice workspace

# OS / System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Frontend dependencies and builds
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/.yarn/*
!frontend/.yarn/patches
!frontend/.yarn/plugins
!frontend/.yarn/releases
!frontend/.yarn/versions

# Backend dependencies, virtual environments, and builds
backend/venv/
backend/.venv/
backend/env/
backend/ENV/
backend/__pycache__/
backend/*.py[cod]
backend/*.so
backend/build/
backend/dist/
backend/*.egg-info/
backend/uploads/

# Environment files and sensitive configs (frontend and backend)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.development
.env.test
.env.production
.env.staging
*.env
*.pem

# Local databases
backend/*.db
backend/*.db-journal
backend/*.sqlite3

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Other tools/caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.tsbuildinfo
